{
  "dashboard": {
    "title": "Brain Storm - NestJS Metrics",
    "tags": ["nestjs", "brain-storm"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "HTTP Requests Total",
        "type": "graph",
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{method}} {{route}} - {{status_code}}"
          }
        ]
      },
      {
        "id": 2,
        "title": "Credentials Issued",
        "type": "stat",
        "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "credential_issued_total",
            "legendFormat": "{{credential_type}}"
          }
        ]
      },
      {
        "id": 3,
        "title": "BST Tokens Minted",
        "type": "stat",
        "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "bst_minted_total"
          }
        ]
      },
      {
        "id": 4,
        "title": "Stellar RPC Latency (p95)",
        "type": "graph",
        "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(stellar_rpc_latency_seconds_bucket[5m]))",
            "legendFormat": "{{method}} - {{status}}"
          }
        ]
      },
      {
        "id": 5,
        "title": "Node.js Memory Usage",
        "type": "graph",
        "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "process_resident_memory_bytes",
            "legendFormat": "Memory"
          }
        ]
      }
    ],
    "schemaVersion": 16,
    "version": 1
  }
}
